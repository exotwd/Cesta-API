# Runtime. APP_ENV=production enables strict secret and CORS validation.
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8080
REQUEST_BODY_LIMIT_BYTES=1048576
CORS_ALLOWED_ORIGINS=*

DATABASE_URL=postgres://cesta:cesta@localhost:5432/cesta
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_ACQUIRE_TIMEOUT_SECONDS=10
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-only-change-me
REFRESH_TOKEN_SECRET=dev-only-change-me-too
STORAGE_DIR=storage
GGU_LATEST_BASE_URL=https://data.jr.ggu.cz/results/latest/
PID_GTFS_URL=https://data.pid.cz/PID_GTFS.zip
PID_LINES_URL=https://data.pid.cz/geodata/Linky_7d_WGS84.json
PID_API_TOKEN=
PID_POLL_INTERVAL_SECONDS=20
IDS_JMK_POLL_INTERVAL_SECONDS=30
DUK_POLL_INTERVAL_SECONDS=30
SCHEDULE_UPDATE_INTERVAL_SECONDS=21600
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
RUST_LOG=info
USE_MOCK_DATA=false
USE_MOCK_REALTIME=false

# ČD Ticket API partner integration. Keep credentials in the deployment secret store.
CD_TICKET_API_BASE_URL=https://ticket-api.cd.cz/v1
CD_TICKET_API_USER=
# Prefer a mounted secret file in production. PEM-in-env supports escaped newlines.
CD_TICKET_API_PRIVATE_KEY_FILE=
CD_TICKET_API_PRIVATE_KEY_PEM=
CD_TICKET_API_DESCRIPTION=Cesta API
CD_TICKET_API_LANGUAGE=cs
CD_TICKET_API_TIMEOUT_SECONDS=15
CD_TICKET_REFUND_RECONCILE_SECONDS=300
CD_TICKET_CORRELATION_TOLERANCE_MINUTES=10

# Adapter contract documented in docs/cd-ticketing-frontend-handoff.md.
PAYMENT_PROVIDER_BASE_URL=
PAYMENT_PROVIDER_API_KEY=
MOBILE_CHECKOUT_RETURN_URL=jedes://ticketing/checkout/return
MOBILE_CHECKOUT_CANCEL_URL=jedes://ticketing/checkout/cancel

